{
  "manifest_version": 3,
  "name": "Tesla Price History",
  "version": "0.1.0",
  "description": "Show how each Tesla used-car listing has been repriced over time, directly on tesla.com.",
  "content_scripts": [
    {
      "matches": [
        "https://www.tesla.com/*/inventory/used/m3*",
        "https://www.tesla.com/*/inventory/used/my*",
        "https://www.tesla.com/*/inventory/used/ms*",
        "https://www.tesla.com/*/inventory/used/mx*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
