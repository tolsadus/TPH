{
  "manifest_version": 3,
  "name": "Tesla Price History",
  "version": "0.0.4",
  "description": "Show how each Tesla used-car listing has been repriced over time, directly on tesla website.",
  "content_scripts": [
    {
      "matches": [
        "https://www.tesla.com/*/inventory/used/m3*",
        "https://www.tesla.com/*/inventory/used/my*",
        "https://www.tesla.com/*/inventory/used/ms*",
        "https://www.tesla.com/*/inventory/used/mx*",
        "https://www.tesla.com/*/inventory/used/ct*",
        "https://www.tesla.com/inventory/used/m3*",
        "https://www.tesla.com/inventory/used/my*",
        "https://www.tesla.com/inventory/used/ms*",
        "https://www.tesla.com/inventory/used/mx*",
        "https://www.tesla.com/inventory/used/ct*",
        "https://www.tesla.cn/*/inventory/used/m3*",
        "https://www.tesla.cn/*/inventory/used/my*",
        "https://www.tesla.cn/*/inventory/used/ms*",
        "https://www.tesla.cn/*/inventory/used/mx*",
        "https://www.tesla.cn/*/inventory/used/ct*",
        "https://www.tesla.cn/inventory/used/m3*",
        "https://www.tesla.cn/inventory/used/my*",
        "https://www.tesla.cn/inventory/used/ms*",
        "https://www.tesla.cn/inventory/used/mx*",
        "https://www.tesla.cn/inventory/used/ct*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
